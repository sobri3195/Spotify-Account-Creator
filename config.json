{
    "delays": {
        "min_typing_delay": 0.1,
        "max_typing_delay": 0.3,
        "min_page_load_delay": 2,
        "max_page_load_delay": 4,
        "min_attempt_delay": 5,
        "max_attempt_delay": 10
    },
    "retry_attempts": 3,
    "success_indicators": [
        "success-message",
        "account-created",
        "welcome-page",
        "welcome-container",
        "account-success"
    ],
    "proxy_settings": {
        "rotate_on_failure": true,
        "max_retries": 3
    },
    "logging": {
        "level": "INFO",
        "file": "spotify_creator.log"
    }
} 