{
    "delays": {
        "min_typing_delay": 0.1,
        "max_typing_delay": 0.3,
        "min_page_load_delay": 2,
        "max_page_load_delay": 4,
        "min_attempt_delay": 5,
        "max_attempt_delay": 10,
        "min_action_delay": 0.8,
        "max_action_delay": 2.0,
        "min_scroll_delay": 0.8,
        "max_scroll_delay": 1.6
    },
    "retry_attempts": 3,
    "success_indicators": [
        "success-message",
        "account-created",
        "welcome-page",
        "welcome-container",
        "account-success"
    ],
    "post_creation": {
        "mode": "account_only",
        "playlist_url": "https://open.spotify.com/playlist/YOUR_PLAYLIST_ID",
        "max_artists_to_follow": 25,
        "max_playlist_scrolls": 12
    },
    "proxy_settings": {
        "rotate_on_failure": true,
        "max_retries": 3
    },
    "logging": {
        "level": "INFO",
        "file": "spotify_creator.log"
    }
}
